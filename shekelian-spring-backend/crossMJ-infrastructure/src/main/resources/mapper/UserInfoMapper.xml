<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.avalon.jpcap.infrastructure.mapper.UserInfoMapper">
    <resultMap id="resultMap" type="com.avalon.jpcap.repository.po.UserInfoPO">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="pin" property="pin" jdbcType="VARCHAR"/>
        <result column="plat_form" property="platform" jdbcType="TINYINT"/>
        <result column="plat_form_identity" property="platformPin" jdbcType="VARCHAR"/>
        <result column="nick_name" property="nickName" jdbcType="VARCHAR"/>
        <result column="img_url" property="imgUrl" jdbcType="VARCHAR"/>
        <result column="ext_json" property="extJson" jdbcType="VARCHAR"/>
        <result column="created" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="modified" property="modifiedTime" jdbcType="TIMESTAMP"/>
        <result column="creator" property="creator" jdbcType="VARCHAR"/>
        <result column="modifier" property="modifier" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List" >
        id, pin, plat_form, plat_form_identity, ext_json,
        created, modified, creator, modifier
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into takevideo_user_info (pin, plat_form, plat_form_identity, nick_name, img_url, ext_json,
                                         created, modified, creator, modifier)
        values (#{pin},#{platform}, #{platformPin}, #{nickName}, #{imgUrl}, #{extJson},
                now(), now(), #{creator}, #{modifier})
    </insert>

    <select id="selectById" resultMap="resultMap">
        select <include refid="Base_Column_List"/>
        from takevideo_user_info
        <where>
            id = #{id,jdbcType=BIGINT}
            and
            yn = 1
        </where>
    </select>

    <select id="selectList" resultMap="resultMap">
        select <include refid="Base_Column_List"/>
        from takevideo_user_info
        <where>
            plat_form = #{platform,jdbcType=TINYINT}
            and
            plat_form_identity = #{platformPin,jdbcType=VARCHAR}
            and
            yn = 1
        </where>
    </select>

    <update id="updateUser">
        update takevideo_user_info
        <set>
            <if test="pin != null">
                pin = #{pin,jdbcType=VARCHAR},
            </if>
            <if test="platform != null">
                plat_form = #{platform,jdbcType=TINYINT},
            </if>
            <if test="platformPin != null">
                plat_form_identity = #{platformPin,jdbcType=VARCHAR},
            </if>
            <if test="nickName !=null and nickName != ''">
                nick_name = #{nickName,jdbcType=VARCHAR},
            </if>
            <if test="imgUrl !=null and imgUrl != ''">
                img_url = #{imgUrl,jdbcType=VARCHAR},
            </if>
            <if test="modifier != null and modifier != ''">
                modifier = #{modifier,jdbcType=VARCHAR},
            </if>
            modified = now()
        </set>
        <where>
            <if test="id != null">
                id = #{id,jdbcType=BIGINT}
            </if>
            <if test="platform != null">
                and plat_form = #{platform,jdbcType=INTEGER}
            </if>
            <if test="platformPin != null">
                and plat_form_identity = #{platformPin,jdbcType=VARCHAR}
            </if>
            and
            yn = 1
        </where>
    </update>


</mapper>